import numpy as np
import matplotlib.pyplot as plt

# Paramètres physiques
g = 9.81          # gravité
l = 0.25          # longueur du pendule (m)

# Paramètres numériques
dt = 0.001        # très petit pas pour limiter l'instabilité
n = 10000         # nombre d'itérations

def calcul_T_fonction_w0(w0_values, theta0=0.001, dt=0.001, n=10000):
    """
    Calcule la période T en fonction de w0 (pulsation)
    
    Paramètres:
    -----------
    w0_values : array ou float
        Valeurs de pulsation w0
    theta0 : float
        Angle initial (en radians)
    dt : float
        Pas de temps pour la simulation
    n : int
        Nombre d'itérations
    
    Retour:
    -------
    w0_values : array
        Valeurs de w0
    T_values : array
        Période correspondante pour chaque w0
    """
    
    # Convertir w0_values en array si nécessaire
    if isinstance(w0_values, (int, float)):
        w0_values = np.array([w0_values])
    else:
        w0_values = np.array(w0_values)
    
    T_values = []
    T_theo_values = []
    
    for w0 in w0_values:
        # Stockage
        theta = np.zeros(n)
        omega = np.zeros(n)
        t = np.zeros(n)
        T_liste = []
        
        # Conditions initiales
        theta[0] = theta0
        omega[0] = 0.0
        t_max = 0
        
        # Méthode d'Euler
        for i in range(n-1):
            omega[i+1] = omega[i] - w0**2 * np.sin(theta[i]) * dt
            theta[i+1] = theta[i] + omega[i+1] * dt
            t[i+1] = t[i] + dt
        
        # Calcul de T avec des max locaux
        for i in range(1, n-1):
            if theta[i-1] < theta[i] and theta[i] > theta[i+1]:  # max locaux
                T_liste.append(t[i] - t_max)
                t_max = t[i]
        
        # Moyenne des périodes détectées
        if len(T_liste) > 0:
            T_values.append(np.mean(T_liste[1:]))  # On ignore la première (incomplète)
        else:
            T_values.append(np.nan)

        #Calcul de la période théorique 
        T0 = 2*np.pi/w0
        # On évite x = theta0
        eps = 1e-9
        x = np.linspace(0, theta0 - eps, 1000)#plus on augmente n plus on rapproche la solution théorique de la réalité
        f = 1.0/np.sqrt(2*(np.cos(x) - np.cos(theta0)))
        integrale = np.trapezoid(f, x)
        T_theo = (2*T0/np.pi)*integrale
        T_theo_values.append(T_theo)
    return w0_values, np.array(T_values), np.array(T_theo_values)


def plot_T_vs_w0(w0_min=1, w0_max=20, nb_points=50, theta0=0.001):
    """
    Trace un graphique de T en fonction de w0
    
    Paramètres:
    -----------
    w0_min : float
        Valeur minimale de w0
    w0_max : float
        Valeur maximale de w0
    nb_points : int
        Nombre de points à calculer
    theta0 : float
        Angle initial (en radians)
    """
    
    # Générer les valeurs de w0
    w0_values = np.linspace(w0_min, w0_max, nb_points)
    
    # Calculer T pour chaque w0
    w0_vals, T_vals, T_theo_vals = calcul_T_fonction_w0(w0_values, theta0=theta0)
    
    # Affichage
    plt.figure(figsize=(12, 6))
    plt.plot(w0_vals, T_vals, 'o-', label="T numérique", linewidth=2, markersize=5)
    plt.plot(w0_vals, T_theo_vals, '--', label="T théorique (avec intégrale elliptique)", linewidth=2)
    
    # Calcul de T0 simple : T0 = 2π/w0
    T0_simple = 2*np.pi / w0_vals
    plt.plot(w0_vals, T0_simple, '--', label="T₀ = 2π/w₀ (simple)", linewidth=2, color='red', alpha=0.5)
    
    plt.xlabel("Pulsation w₀ (rad/s)", fontsize=12)
    plt.ylabel("Période T (s)", fontsize=12)
    plt.title("Période T en fonction de la pulsation w₀", fontsize=14)
    plt.legend(fontsize=11)
    plt.grid(True, alpha=0.3)
    plt.tight_layout()
    plt.show()


def plot_T0_minus_Ttheo_vs_w0(w0_min=1, w0_max=20, nb_points=50, theta0=0.001, savepath=None):
    """
    Trace la différence T0_simple - T_théo (où T0_simple = 2π/w0)
    en fonction de w0 et sauvegarde la figure si `savepath` est fourni.
    """
    # Générer les valeurs de w0
    w0_values = np.linspace(w0_min, w0_max, nb_points)

    # Calculer les périodes
    w0_vals, T_vals, T_theo_vals = calcul_T_fonction_w0(w0_values, theta0=theta0)

    # Calcul simple T0 = 2π / w0
    T0_simple = 2 * np.pi / w0_vals

    # Différence
    diff = T0_simple - T_theo_vals

    # Tracé
    plt.figure(figsize=(10, 5))
    plt.plot(w0_vals, diff, 'o-', color='C2', linewidth=2, markersize=5)
    plt.xlabel("Pulsation w₀ (rad/s)", fontsize=12)
    plt.ylabel("T₀ - T_théo (s)", fontsize=12)
    plt.title("Différence T₀ (2π/w₀) - T_théo en fonction de w₀", fontsize=14)
    plt.grid(True, alpha=0.3)
    plt.tight_layout()
    if savepath:
        plt.savefig(savepath, dpi=300)
    plt.show()


