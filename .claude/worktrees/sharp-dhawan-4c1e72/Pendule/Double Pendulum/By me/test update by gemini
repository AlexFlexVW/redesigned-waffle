import numpy as np
import matplotlib.pyplot as plt

g = 9.81          
l = 0.25          
# w0 n'est pas nécessaire pour la simulation numérique directe

# Paramètres numériques
dt = 0.0001       
n = 100000        

# Conditions initiales (en radians)
theta1_0 = 1.0  
theta2_0 = 1.5 
omega1_0 = 0.0
omega2_0 = 0.0

# Stockage : Tableaux numpy initialisés à 0
theta = np.zeros((n, 2))
omega = np.zeros((n, 2))
t = np.zeros(n)

# Initialisation
theta[0, 0] = theta1_0
theta[0, 1] = theta2_0
omega[0, 0] = omega1_0
omega[0, 1] = omega2_0

def ddtheta(theta1, theta2, omega1, omega2):
    """
    Calcule les accélérations angulaires pour un double pendule
    avec masses égales (m1=m2=1) et longueurs égales (l1=l2=l).
    """
    delta = theta1 - theta2
    den = 2.0 - np.cos(delta)**2  # Le déterminant commun
    
    # Équation pour theta1''
    num1 = (omega2**2 * np.sin(delta) + 
            2.0 * g / l * np.sin(theta1) - 
            g / l * np.sin(theta2) * np.cos(delta) + 
            omega1**2 * np.sin(delta) * np.cos(delta))
    # Note: Les équations standard ont souvent des signes différents selon l'orientation
    # Voici la forme standard robuste :
    term1_num = -g * (2 * np.sin(theta1) - np.sin(theta2) * np.cos(delta))
    term1_dyn = -np.sin(delta) * (omega2**2 + omega1**2 * np.cos(delta)) * l
    # Correction pour s'assurer des unités, on factorise souvent g et l
    
    # Formule compacte vérifiée (Réf: ScienceWorld / Wikipedia Double Pendulum)
    # theta1''
    num1 = -g * (2 * np.sin(theta1) - np.sin(theta2) * np.cos(delta)) \
           - np.sin(delta) * (omega2**2 * l + omega1**2 * l * np.cos(delta))
    d2theta1 = num1 / (l * (2 - np.cos(delta)**2))

    # theta2''
    num2 = 2 * np.sin(delta) * (omega1**2 * l * (2) + g * np.cos(theta1) + omega2**2 * l * np.cos(delta)) 
    # Cette forme ci-dessus est parfois instable, voici la version couplée exacte :
    
    # Version claire et robuste :
    s_delta = np.sin(delta)
    c_delta = np.cos(delta)
    
    # Accélération 1
    num1 = -g * (2 * np.sin(theta1) - np.sin(theta2) * c_delta) - s_delta * (omega2**2 * l + omega1**2 * l * c_delta)
    val1 = num1 / (l * (2 - c_delta**2))
    
    # Accélération 2
    num2 = 2 * s_delta * (omega1**2 * l + g * np.cos(theta1) + omega2**2 * l * c_delta * 0.5) # Attention coefs
    # Simplifions avec la forme canonique exacte pour m1=m2 :
    
    val2 = (2 * s_delta * (omega1**2 * l + g * np.cos(theta1) + omega2**2 * l * c_delta) ) 
    # Correction num2 :
    val2 = (2 * s_delta * (omega1**2*l + g*(np.cos(theta1)) + omega2**2*l*c_delta/2.0)) # Non, c'est compliqué à écrire de tête.
    
    # --- RESTART FORMULES EXACTES (Source: Wolfram MathWorld, m1=m2) ---
    mu = 1 + 1 # m1/m2 + 1 = 2
    
    # Theta 1 ''
    num1_g = -g * (2 * np.sin(theta1) - np.sin(theta2) * c_delta)
    num1_dyn = -l * s_delta * (omega2**2 + omega1**2 * c_delta) # Erreur signe souvent ici
    # La formule correcte qui marche à tous les coups :
    d2th1 = (g*(np.sin(theta2)*c_delta - 2*np.sin(theta1)) - l*s_delta*(omega2**2 + omega1**2*c_delta)) / (l*(2 - c_delta**2))
    
    # Theta 2 ''
    d2th2 = (2*s_delta*(omega1**2*l + g*np.cos(theta1) + omega2**2*l*c_delta/2.0)) # Toujours faux
    
    # Utilisons la substitution matricielle qui est infaillible :
    # Equation 1: 2*l*th1'' + l*c_delta*th2'' + l*s_delta*w2^2 + 2*g*s_th1 = 0
    # Equation 2: l*c_delta*th1'' + l*th2'' - l*s_delta*w1^2 + g*s_th2 = 0
    
    # On isole th1'' et th2'' :
    # A * X = B
    # A = [[2, c_delta], [c_delta, 1]]
    # B = [[-l*s_delta*w2^2 - 2*g*sin(th1)], [l*s_delta*w1^2 - g*sin(th2)]] / l
    
    b1 = -np.sin(delta)*omega2**2 - 2*(g/l)*np.sin(theta1)
    b2 = np.sin(delta)*omega1**2 - (g/l)*np.sin(theta2)
    
    det = 2 - c_delta**2
    
    val1 = (b1 * 1 - b2 * c_delta) / det
    val2 = (2 * b2 - b1 * c_delta) / det
    
    return val1, val2

# Boucle Temporelle (Euler semi-implicite améliore un peu la stabilité)
for i in range(n-1):
    d2th1, d2th2 = ddtheta(theta[i, 0], theta[i, 1], omega[i, 0], omega[i, 1])
    
    # Mise à jour des vitesses
    omega[i+1, 0] = omega[i, 0] + d2th1 * dt
    omega[i+1, 1] = omega[i, 1] + d2th2 * dt
    
    # Mise à jour des positions (utiliser la vitesse i+1 est plus stable : Euler Symplectique)
    theta[i+1, 0] = theta[i, 0] + omega[i+1, 0] * dt
    theta[i+1, 1] = theta[i, 1] + omega[i+1, 1] * dt
    
    t[i+1] = t[i] + dt

# --- Calcul Correct de l'Énergie ---
E_kinetic = np.zeros(n)
E_potential = np.zeros(n)
E_total = np.zeros(n)

# On normalise par m*l^2
for i in range(n):
    th1, th2 = theta[i, 0], theta[i, 1]
    w1, w2 = omega[i, 0], omega[i, 1]
    delta = th1 - th2
    
    # Energie Cinétique T = 0.5 * m * l^2 * (2*w1^2 + w2^2 + 2*w1*w2*cos(delta))
    # ATTENTION : facteur 2 sur w1^2 car la masse 1 porte la masse 2
    term_k = 2 * w1**2 + w2**2 + 2 * w1 * w2 * np.cos(delta)
    E_kinetic[i] = 0.5 * term_k # (facteur m*l^2 implicite = 1)
    
    # Energie Potentielle V = -m*g*l * (2*cos(th1) + cos(th2))
    # ATTENTION : facteur 2 sur cos(th1) car masse 1 soutient masse 2
    term_p = -(2 * np.cos(th1) + np.cos(th2))
    E_potential[i] = term_p * (g/l) # ajustement dimensionnel si on veut tout en rad/s^2 ou J
    
    # Pour garder cohérence avec ton code précédent qui normalisait par mgl :
    # K_norm = K / (mgl) = (0.5 m l^2 term_k) / (mgl) = (l/2g) * term_k
    E_kinetic[i] = (l / (2*g)) * term_k
    E_potential[i] = term_p # car divisé par mgl, il reste juste les cos
    
    E_total[i] = E_kinetic[i] + E_potential[i]

# Affichage
plt.figure(figsize=(10, 8))

plt.subplot(2, 1, 1)
plt.plot(t, theta[:, 0], label=r'$\theta_1$')
plt.plot(t, theta[:, 1], label=r'$\theta_2$')
plt.ylabel('Angle (rad)')
plt.title('Double Pendule (Euler Symplectique)')
plt.legend()
plt.grid(True)

plt.subplot(2, 1, 2)
plt.plot(t, E_total, label='Énergie Totale', color='red')
plt.plot(t, E_kinetic, label='Cinétique', alpha=0.5)
plt.plot(t, E_potential, label='Potentielle', alpha=0.5)
plt.ylabel('Énergie (en J)')
plt.xlabel('Temps (en s)')
plt.legend()
plt.grid(True)

plt.tight_layout()
plt.show()