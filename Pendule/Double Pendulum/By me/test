import numpy as np
import matplotlib.pyplot as plt


g = 9.81          # gravité
l = 0.25          # longueur du pendule (m)
w0 = np.sqrt(g/l) # pulsation

# Paramètres numériques
dt = 0.0001        # très petit pas pour limiter l’instabilité
n = 100000         # nombre d’itérations

# Conditions initiales (petits angles : en radians)
theta1_0 = 1  #np.deg2rad(10)#on convertit en radian car les fonctions cos, sin... prennent des radians en entrée
theta2_0 = 1.5 #np.deg2rad(15)
omega1_0 = 0.0
omega2_0 = 0.0

# Stockage
# Crée un tableau de n lignes et 2 colonnes
theta = np.zeros((n, 2))
omega = np.zeros((n, 2))
t = np.zeros(n)
T_liste=[]

theta[0][0] = theta1_0
theta[0][1] = theta2_0
omega[0][0] = omega1_0
omega[0][1] = omega2_0
t_max=0 #le premier maximum est atteint en 0 et puis on actualise

def ddtheta (theta1,theta2,omega1,omega2):
    delta=theta1-theta2
    coef1 = (4/3) - (3/4)*np.cos(delta)**2
    term1 = np.sin(delta)*(omega2**2 + (3/2)*(omega1**2)*np.cos(delta)) + (3*g/l)*(np.sin(theta1) - (1/2)*np.sin(theta2)*np.cos(delta))
    d2theta1_dt2 = coef1*(-1/2)*term1
    
    coef2 = 3/2 * (1 - 3/16 * np.cos(delta)**2)
    term2 = np.sin(delta)*omega1**2 + (3/8)*(omega2**2)*np.sin(delta)*np.cos(delta) - (g/l)*(np.sin(theta2) - (9/8)*np.sin(theta1)*np.cos(delta))
    d2theta2_dt2 = coef2 * term2
    return d2theta1_dt2, d2theta2_dt2


# Méthode d'Euler
for i in range(n-1):
    d2theta1, d2theta2 = ddtheta(theta[i][0], theta[i][1], omega[i][0], omega[i][1])
    omega[i+1][0] = omega[i][0] + d2theta1 * dt
    omega[i+1][1] = omega[i][1] + d2theta2 * dt
    theta[i+1][0] = theta[i][0] + omega[i+1][0] * dt
    theta[i+1][1] = theta[i][1] + omega[i+1][1] * dt
    t[i+1] = t[i] + dt

# Calcul de l'énergie mécanique (masses et longueurs égales : m1=m2=m, l1=l2=l)
# Normalisation par m*g*l
m = 1.0  # masse (unité)
E_kinetic = np.zeros(n)
E_potential = np.zeros(n)
E_total = np.zeros(n)

for i in range(n):
    # Énergie cinétique normalisée par (m*g*l)
    delta = theta[i][0] - theta[i][1]
    E_kinetic[i] = (1/2) * (omega[i][0]**2 + omega[i][1]**2 + 2*omega[i][0]*omega[i][1]*np.cos(delta)) * (l**2 / g)
    
    # Énergie potentielle normalisée par (m*g*l) (zéro au point de suspension)
    E_potential[i] = -(np.cos(theta[i][0]) + np.cos(theta[i][1]))
    
    # Énergie mécanique totale
    E_total[i] = E_kinetic[i] + E_potential[i]

# Affichage des angles
plt.figure(figsize=(12, 6))
plt.plot(t, theta[:, 0], label="θ₁(t) numérique", linewidth=1.5)
plt.plot(t, theta[:, 1], label="θ₂(t) numérique", linewidth=1.5)

plt.xlabel("Temps (s)", fontsize=12)
plt.ylabel("Angle (rad)", fontsize=12)
plt.title("Double Pendule — Angles θ₁ et θ₂ en fonction du temps (Euler explicite)", fontsize=13)
plt.legend(fontsize=11)
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.show()

# Affichage de l'énergie mécanique
plt.figure(figsize=(12, 6))
plt.plot(t, E_kinetic, label="Énergie cinétique K", linewidth=1.5, alpha=0.8)
plt.plot(t, E_potential, label="Énergie potentielle U", linewidth=1.5, alpha=0.8)
plt.plot(t, E_total, label="Énergie mécanique totale E = K + U", linewidth=2, color='red', alpha=0.7)

plt.xlabel("Temps (s)", fontsize=12)
plt.ylabel("Énergie (J/(m·g·l))", fontsize=12)
plt.title("Double Pendule — Évolution de l'énergie mécanique", fontsize=13)
plt.legend(fontsize=11)
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.show()
