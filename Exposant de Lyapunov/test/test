# suite logistique - determination d’exposant de Lyapunov
import numpy as np # importer le module NumPy comme "np"
import matplotlib.pyplot as plt # importer le module Matplotlib comme "plt"

def logistique(rf,x): # la suite logistique
    return 4*rf*x*(1-x)

r = 0.751 # valeur du parametre r
x = 0.5 # x0
DeltaX = 1e-8 # magnitude de perturbation
for n in range(0,1000): # jeter les 1000 premiers iterations
x = logistique (r, x)
xp = x + DeltaX # perturber